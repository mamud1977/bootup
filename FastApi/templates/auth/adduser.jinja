{% extends "base.html" %}

{% block title %}Login{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ url_for('static', path='css/login.css') }}">
{% endblock %}

{% block content %}

<div class="login-container">

    <form id="user-form" method="post" action="/auth/adduser">

        <h3>User Details</h3>
        <!-- User Details Box -->
        <div class="input-box">

            <!-- Name -->
            <label for="fullname">Full Name</label>
            <input 
                type="text" 
                id="fullname" 
                name="fullname" 
                placeholder="Full Name" 
                value="{{ form_data.get('fullname', '') }}" 
                required >

            <!-- Phone Number -->
            <label for="phone">Phone Number</label>
            <input 
                type="tel" 
                id="phone" 
                name="phone" 
                pattern="[0-9]{10}" placeholder="10-digit number"
                value="{{ form_data.get('phone', '') }}"
                required >

            <!-- User Type -->
            <label>User Type</label>
            <span class="radio-inline">
                <input 
                    type="radio" 
                    id="participant" 
                    name="usertype" 
                    value="participant" 
                    {% if form_data.get('usertype') == 'participant' or not form_data.get('usertype') %}checked{% endif %}
                    >
                <label for="participant">Participant</label>
            </span>

            <span class="radio-inline">
                <input 
                    type="radio" 
                    id="event-admin" 
                    name="usertype" 
                    value="event-admin"
                    {% if form_data.get('usertype') == 'event-admin' %}checked{% endif %}
                    >
                <label for="event-admin">Event Admin</label>
            </span>

            <!-- Date of Birth -->
            <label for="dob">Date of Birth</label>
            <input 
                type="date" 
                id="dob" 
                name="dob"
                value="{{ form_data.get('dob', '') }}"
                required>
        </div>

        <h3>Login Details</h3>
        <div class="input-box">
        <label for="email">Email:</label>
        <input 
            type="email" 
            id="email" 
            name="email" 
            value="{{ form_data.get('email', '') }}"
            required>

        <!-- Password -->
        <label for="password">Password:</label>
        <input 
            type="password" 
            id="password" 
            name="password" 
            required 
            minlength="6"
            placeholder="Enter minimum 6 characters password"
            value="{{ form_data.get('password', '') }}"
            >
        </div>
        
        <button type="submit" class="btn">Submit</button>
        <p id="form-message"></p>
       
    </form>
</div>

{% endblock %}

{% block extra_js %}
<script>

document.addEventListener("DOMContentLoaded", function () {
    // --- Get form elements ---
    const form = document.getElementById("user-form");
    const msgEl = document.getElementById("form-message");

    // --- Initialize server message ---
    const serverMessage = {{ message | tojson | default("null") }};
    const serverStatus  = {{ status  | tojson | default("null") }};

    if (msgEl && serverMessage) {
        msgEl.textContent = serverMessage;
        msgEl.style.color = serverStatus === "success" ? "green" : "red";
    }

    // --- Update message on any form change ---
    if (form && msgEl) {
        form.addEventListener("input", function () {
            msgEl.textContent = "Please save your changes";
            msgEl.style.color = "red";
        });
    }



    // --- DOB toggle logic ---
    const dobField = document.getElementById("dob");
    const participantRadio = document.getElementById("participant");
    const eventAdminRadio = document.getElementById("event-admin");

    if (dobField && participantRadio && eventAdminRadio) {
        const toggleDob = () => {
            dobField.disabled = eventAdminRadio.checked;
            if (eventAdminRadio.checked) dobField.value = "";
        };

        toggleDob();
        participantRadio.addEventListener("change", toggleDob);
        eventAdminRadio.addEventListener("change", toggleDob);
    }




});

</script>
{% endblock %}
