## apply_event.jinja

{% extends "base.html" %}

{% block title %}Apply Event{% endblock %}

{% block content %}

<h1>Apply Event</h1>

<h1>Apply for Event {{ eventID }}</h1>

<select name="eventID" required>
  {% for event in events %}
    <option value="{{ event.eventID }}" {% if event.eventID == selected_event_id %}selected{% endif %}>
      {{ event.eventName }} - {{ event.eventYear }} ({{ event.eventArea }})
    </option>
  {% endfor %}
</select>


 <script src="{{ url_for('static', path='js/eventbuilder.js') }}"></script>
{% endblock %}